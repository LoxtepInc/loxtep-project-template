{
  "$schema": "https://loxtep.com/schemas/blueprint/pipeline.json",
  "blueprint_type": "pipeline",
  "slug": "connector-ingestion",
  "name": "Connector Ingestion Pipeline",
  "description": "Auto-provisioned ingestion pipeline for connector entities. Syncs data from authenticated connectors (Shopify, Stripe, etc.) to data products with graph storage enabled.",
  "version": "1.0.0",
  "tags": ["connector", "api", "polling", "ingestion", "graph"],
  "use_cases": [
    "Auto-provision on connector OAuth success",
    "Sync orders, products, customers from e-commerce connectors",
    "Graph storage for entity context resolution"
  ],
  "entity": {
    "pipeline_id": "{{PIPELINE_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "name": "{{PIPELINE_NAME}}",
    "description": "{{PIPELINE_DESCRIPTION}}",
    "template_id": "{{TEMPLATE_ID}}",
    "pipeline_type": "ingestion",
    "domain_id": "{{DOMAIN_ID}}",
    "configuration": {
      "schedule": "0 */6 * * *",
      "batch_size": 500,
      "sync_mode": "realtime",
      "storage_graph": { "enabled": true }
    },
    "deployment": null,
    "status": "inactive",
    "metrics": {},
    "metadata": {
      "blueprint_slug": "connector-ingestion",
      "ingestion_type": "connector_api_poll",
      "connector_id": "{{CONNECTOR_ID}}",
      "sync_entity": "{{SYNC_ENTITY}}",
      "storage_graph": { "enabled": true }
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "placeholders": {
    "{{PIPELINE_ID}}": "Generated UUID",
    "{{ORGANIZATION_ID}}": "Organization ID",
    "{{PROJECT_ID}}": "Project ID",
    "{{PIPELINE_NAME}}": "e.g. Shopify Orders",
    "{{PIPELINE_DESCRIPTION}}": "Ingestion pipeline for connector entity",
    "{{TEMPLATE_ID}}": "Stable template ID for connector-ingestion",
    "{{DOMAIN_ID}}": "Domain UUID",
    "{{CONNECTOR_ID}}": "Connector UUID",
    "{{SYNC_ENTITY}}": "Entity type (orders, products, customers)",
    "{{CREATED_AT}}": "ISO 8601",
    "{{UPDATED_AT}}": "ISO 8601"
  }
}
