{
  "$schema": "https://loxtep.com/schemas/blueprint/connector.json",
  "blueprint_type": "connector",
  "slug": "bigcommerce",
  "name": "BigCommerce Connector",
  "description": "Connect to BigCommerce stores for orders, customers, and products. Non-Shopify DTC brands (~3% e-commerce market share). OAuth 2.0.",
  "version": "1.0.0",
  "tags": ["bigcommerce", "e-commerce", "orders", "products"],
  "use_cases": [
    "Order event streaming",
    "Product catalog sync",
    "Customer data integration"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "bigcommerce",
    "name": "BigCommerce",
    "description": "BigCommerce e-commerce platform connector for orders, customers, and products",
    "category": "e_commerce",
    "auth_type": "oauth2",
    "supported_directions": ["inbound"],
    "supported_entities": ["orders", "customers", "products", "inventory"],
    "supports_webhooks": true,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "blueprint_slug": "bigcommerce"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {
      "store_hash": "{{STORE_HASH}}"
    }
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{STORE_HASH}}": "BigCommerce store hash from Store API URL",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
