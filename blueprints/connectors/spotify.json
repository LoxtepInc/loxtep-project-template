{
  "$schema": "https://loxtep.com/schemas/blueprint/connector.json",
  "blueprint_type": "connector",
  "slug": "spotify",
  "name": "Spotify Connector",
  "description": "Connect to Spotify to ingest user profile, playlists, saved tracks, and listening history. Uses OAuth 2.0 for user authorization.",
  "version": "1.0.0",
  "tags": ["spotify", "music", "playlists", "user-library"],
  "use_cases": [
    "User profile and preferences sync",
    "Playlist and library ingestion",
    "Listening history and analytics"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "connector_type": "spotify",
    "name": "Spotify",
    "description": "Spotify music platform connector for user profile, playlists, and library data",
    "category": "custom",
    "icon_url": "https://developer-assets.spotifycdn.com/images/guidelines/design/icon-framed.svg",
    "documentation_url": "https://developer.spotify.com/documentation/web-api",
    "auth_type": "oauth2",
    "oauth_config": {
      "authorization_url": "https://accounts.spotify.com/authorize",
      "token_url": "https://accounts.spotify.com/api/token",
      "scopes": [
        "user-read-email",
        "user-read-private",
        "playlist-read-private",
        "playlist-read-collaborative",
        "user-library-read",
        "user-top-read"
      ],
      "response_type": "code",
      "grant_type": "authorization_code"
    },
    "supported_directions": ["inbound"],
    "supported_entities": ["user_profile", "playlists", "saved_tracks", "top_artists", "top_tracks"],
    "supports_webhooks": false,
    "supports_polling": true,
    "required_scopes": ["user-read-email", "user-read-private"],
    "required_permissions": null,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "blueprint_slug": "spotify",
      "api_version": "v1"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {
      "api_base_url": "https://api.spotify.com/v1"
    }
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
