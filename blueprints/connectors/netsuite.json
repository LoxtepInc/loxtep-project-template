{
  "$schema": "https://loxtep.com/schemas/blueprint/connector.json",
  "blueprint_type": "connector",
  "slug": "netsuite",
  "name": "NetSuite Connector",
  "description": "Connect to NetSuite ERP via Composio to sync invoices, payments, customers, and GL entries. Uses OAuth 2.0 for authorization.",
  "version": "1.0.0",
  "tags": ["netsuite", "composio", "erp", "finance"],
  "use_cases": [
    "Invoice and payment sync",
    "Customer data integration",
    "General ledger entries"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
