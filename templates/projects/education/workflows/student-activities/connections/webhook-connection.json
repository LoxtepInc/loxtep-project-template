{
  "template_type": "trigger",
  "slug": "student-activities-webhook-connection",
  "name": "Student Activities Webhook Connection",
  "description": "Webhook trigger connection for ingesting student activity events.",
  "version": "1.0.0",
  "tags": [
    "webhook",
    "ingestion",
    "education",
    "student-engagement"
  ],
  "entity": {
