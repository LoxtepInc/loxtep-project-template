{
  "key": "spotify_list_followed_artists",
  "name": "List followed artists",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "limit": { "type": "number" },
      "after": { "type": "string" }
    }
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://api.spotify.com/v1",
    "path": "/me/following",
    "static_headers": { "Accept": "application/json" },
    "header_auth": {
      "header": "Authorization",
      "value_from": "connection.oauth_access_token",
      "bearer_prefix": true
    },
    "query_mapping": {
      "type": "input.type",
      "limit": "input.limit",
      "after": "input.after"
    },
    "omit_empty_query": true
  }
}
