{
  "key": "spotify_get_me",
  "name": "Get current user profile",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://api.spotify.com/v1",
    "path": "/me",
    "static_headers": { "Accept": "application/json" },
    "header_auth": {
      "header": "Authorization",
      "value_from": "connection.oauth_access_token",
      "bearer_prefix": true
    },
    "query_mapping": {},
    "omit_empty_query": true
  }
}
