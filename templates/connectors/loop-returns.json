{
  "$schema": "https://loxtep.com/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "loop-returns",
  "name": "Loop Returns Connector",
  "description": "Connect to Loop Returns to sync returns, reason codes, exchanges, and refund amounts. Popular with 7k+ Shopify stores.",
  "version": "1.0.0",
  "tags": ["loop-returns", "returns", "e-commerce", "shopify"],
  "use_cases": [
    "Returns data sync",
    "Exchange and refund tracking",
    "Return reason analytics"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "loop-returns",
    "name": "Loop Returns",
    "description": "Loop Returns for returns, exchanges, refund amounts, and reason codes",
    "category": "e_commerce",
    "auth_type": "api_key",
    "supported_directions": ["inbound"],
    "supported_entities": ["returns", "reason_codes", "exchanges", "refund_amounts"],
    "supports_webhooks": false,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "loop-returns"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {
      "api_key": "{{API_KEY}}"
    }
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{API_KEY}}": "Loop Returns API key (Settings > API Keys)",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
