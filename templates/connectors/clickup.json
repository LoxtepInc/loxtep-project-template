{
  "$schema": "https://loxtep.com/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "clickup",
  "name": "ClickUp Connector",
  "description": "Connect to ClickUp via Composio to sync tasks, lists, folders, spaces, workspaces, and goals. Uses OAuth 2.0 for authorization.",
  "version": "1.0.0",
  "tags": ["clickup", "composio", "productivity", "project-management"],
  "use_cases": [
    "Task and project sync",
    "Workspace hierarchy ingestion",
    "Goals and lists data integration"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "clickup",
    "name": "ClickUp",
    "description": "ClickUp project management via Composio (tasks, lists, folders, spaces, workspaces, goals)",
    "category": "productivity",
    "auth_type": "oauth2",
    "backend": "composio",
    "supported_directions": ["inbound"],
    "supported_entities": ["workspaces", "tasks", "spaces", "folders", "lists", "goals"],
    "supports_webhooks": false,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "clickup"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {}
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
