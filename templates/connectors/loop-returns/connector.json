{
  "$schema": "https://loxtep.io/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "loop-returns",
  "name": "Loop Returns Connector",
  "description": "Connect to Loop Returns to sync returns (raw return rows from the Loop warehouse API).",
  "version": "1.0.0",
  "tags": ["loop-returns", "returns", "e-commerce", "shopify"],
  "use_cases": ["Returns data sync", "Exchange and refund tracking"],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "loop-returns",
    "name": "Loop Returns",
    "description": "Loop Returns warehouse return list (catalog runtime).",
    "category": "e_commerce",
    "auth_type": "api_key",
    "supported_directions": ["inbound"],
    "supported_entities": ["returns"],
    "supports_webhooks": false,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": { "template_slug": "loop-returns" },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": { "api_key": "{{API_KEY}}" }
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{API_KEY}}": "Loop Returns API key (Settings > API Keys)",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  },
  "connector_package": {
    "schema_version": 1,
    "package_version": "1.0.0",
    "use_catalog_runtime": true,
    "description": "Loop Returns GET /warehouse/return/list via CatalogRuntimeConnector.",
    "execution_policy": {
      "allowed_host_suffixes": ["api.loopreturns.com"],
      "allowed_path_patterns": ["^/api/v1/warehouse/return/list$"]
    },
    "connection_probe": {
      "action_key": "loop_returns_list",
      "records_path": "",
      "required_field": "id",
      "probe_input": {
        "from": "2020-01-01T00:00:00.000Z",
        "filter": "created_at"
      }
    },
    "sync_plan": {
      "entities": {
        "returns": {
          "fetch_action_key": "loop_returns_list",
          "records_path": "",
          "pagination": "since_id",
          "since_query_param": "from",
          "id_field": "id",
          "sync_input_defaults": { "filter": "created_at" }
        }
      }
    },
    "entity_catalog": {
      "returns": {
        "name": "Returns",
        "record_schema_path": "schemas/entities/return-record.schema.json",
        "supports_incremental": true,
        "supports_full_sync": true,
        "supports_webhook": false,
        "default_sync_interval_minutes": 60,
        "max_batch_size": 250
      }
    },
    "actions": [{ "key": "loop_returns_list", "definition_path": "actions/list-returns/definition.json" }]
  }
}
