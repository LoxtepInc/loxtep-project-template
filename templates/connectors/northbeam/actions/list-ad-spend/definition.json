{
  "key": "northbeam_list_ad_spend",
  "name": "List ad spend",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": { "limit": { "type": "number" } }
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://api.northbeam.io/v1",
    "path": "/ad-spend",
    "header_auth": {
      "header": "X-Api-Key",
      "value_from": "connection.api_key"
    },
    "query_mapping": { "limit": "input.limit" },
    "omit_empty_query": true
  }
}
