{
  "key": "s3_source_fetch_files",
  "name": "List S3 objects",
  "description": "List object keys under the configured prefix (ListObjectsV2). Entity type must be \"files\".",
  "version": "1.0.0",
  "type": "action",
  "annotations": {
    "runtime_kind": "platform_native",
    "provider_slug": "s3-source",
    "operation": "fetch_data",
    "read_only": true,
    "destructive": false
  },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "entity_type": {
        "type": "string",
        "description": "Use \"files\" for object listing."
      },
      "cursor": { "type": "string", "description": "S3 ContinuationToken for pagination." },
      "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
      "full_sync": { "type": "boolean" }
    },
    "required": ["entity_type"]
  },
  "execution": {
    "protocol": "platform_native",
    "provider": "s3-source",
    "operation": "fetch_data"
  }
}
