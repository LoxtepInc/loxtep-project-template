{
  "key": "hubspot_search_deals",
  "name": "Search HubSpot deals (incremental)",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "since_epoch_ms": { "type": "number" },
      "after": { "type": "string" }
    }
  },
  "execution": {
    "protocol": "catalog_http_post",
    "method": "POST",
    "base_url_template": "https://api.hubapi.com",
    "path": "/crm/v3/objects/deals/search",
    "static_headers": { "Accept": "application/json" },
    "header_auth": {
      "header": "Authorization",
      "value_from": "connection.oauth_access_token",
      "bearer_prefix": true
    },
    "query_mapping": {},
    "omit_empty_query": true,
    "omit_empty_json_strings": true,
    "json_body": {
      "filterGroups": [
        {
          "filters": [
            {
              "propertyName": "hs_lastmodifieddate",
              "operator": "GTE",
              "value": "{{input.since_epoch_ms}}"
            }
          ]
        }
      ],
      "sorts": [
        { "propertyName": "hs_lastmodifieddate", "direction": "ASCENDING" }
      ],
      "properties": [
        "dealname",
        "amount",
        "dealstage",
        "workflow",
        "closedate",
        "createdate",
        "hs_lastmodifieddate",
        "hubspot_owner_id",
        "description",
        "dealtype",
        "hs_priority",
        "hs_deal_stage_probability",
        "hs_forecast_amount",
        "hs_forecast_probability",
        "hs_closed_amount",
        "hs_is_closed",
        "hs_is_closed_won"
      ],
      "limit": 100,
      "after": "{{input.after}}"
    }
  }
}
