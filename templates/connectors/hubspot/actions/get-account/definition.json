{
  "key": "hubspot_get_account",
  "name": "Get HubSpot account details",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "type": "object",
    "properties": {},
    "additionalProperties": true
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://api.hubapi.com",
    "path": "/account-info/v3/details",
    "static_headers": { "Accept": "application/json" },
    "header_auth": {
      "header": "Authorization",
      "value_from": "connection.oauth_access_token",
      "bearer_prefix": true
    },
    "query_mapping": {},
    "omit_empty_query": true
  }
}
