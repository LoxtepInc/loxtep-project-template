{
  "$schema": "https://loxtep.com/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "fairing",
  "name": "Fairing Connector",
  "description": "Connect to Fairing for post-purchase surveys attributed to orders. Zero-party data enrichment.",
  "version": "1.0.0",
  "tags": ["fairing", "surveys", "post-purchase", "zero-party"],
  "use_cases": [
    "Post-purchase survey data",
    "Order-attributed feedback",
    "Zero-party data sync"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "fairing",
    "name": "Fairing",
    "description": "Fairing post-purchase survey connector attributed to orders",
    "category": "analytics",
    "auth_type": "api_key",
    "supported_directions": ["inbound"],
    "supported_entities": ["surveys", "responses", "attributed_orders"],
    "supports_webhooks": true,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "fairing"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {
      "api_key": "{{API_KEY}}"
    }
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{API_KEY}}": "Fairing API key",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
