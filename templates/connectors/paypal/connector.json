{
  "$schema": "https://loxtep.io/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "paypal",
  "name": "PayPal / Braintree Connector",
  "description": "PayPal REST reporting transactions (OAuth bearer).",
  "version": "1.0.0",
  "tags": ["paypal", "braintree", "payments", "finance"],
  "use_cases": ["Transaction sync", "Payment reconciliation"],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "paypal",
    "name": "PayPal / Braintree",
    "description": "PayPal reporting API (transactions) via catalog runtime.",
    "category": "finance",
    "auth_type": "oauth2",
    "supported_directions": ["inbound"],
    "supported_entities": ["transactions"],
    "supports_webhooks": false,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": true,
    "metadata": { "template_slug": "paypal" },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {}
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  },
  "connector_package": {
    "schema_version": 1,
    "package_version": "1.0.0",
    "use_catalog_runtime": true,
    "description": "PayPal /v1/reporting/transactions via CatalogRuntimeConnector.",
    "execution_policy": {
      "allowed_host_suffixes": ["api.paypal.com"],
      "allowed_path_patterns": ["^/v1/reporting/transactions$"]
    },
    "connection_probe": {
      "action_key": "paypal_list_transactions",
      "records_path": "transaction_details",
      "required_field": "transaction_info.transaction_id",
      "probe_input": { "limit": 1 }
    },
    "sync_plan": {
      "entities": {
        "transactions": {
          "fetch_action_key": "paypal_list_transactions",
          "records_path": "transaction_details",
          "pagination": "query_page_link_next",
          "page_query_param": "page",
          "id_field": "transaction_info.transaction_id"
        }
      }
    },
    "entity_catalog": {
      "transactions": {
        "name": "Transactions",
        "record_schema_path": "schemas/entities/transaction-row.schema.json",
        "supports_incremental": true,
        "supports_full_sync": true,
        "supports_webhook": false,
        "default_sync_interval_minutes": 60,
        "max_batch_size": 100
      }
    },
    "actions": [
      { "key": "paypal_list_transactions", "definition_path": "actions/list-transactions/definition.json" }
    ]
  }
}
