{
  "key": "github_list_repo_pull_requests",
  "name": "List pull requests for a repository",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "limit": { "type": "number" },
      "page": { "type": "number" },
      "state": { "type": "string" },
      "sort": { "type": "string" },
      "direction": { "type": "string" }
    }
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://api.github.com",
    "path": "/repos/{{connection.custom_settings.owner}}/{{connection.custom_settings.repository}}/pulls",
    "static_headers": {
      "Accept": "application/vnd.github+json",
      "X-GitHub-Api-Version": "2022-11-28"
    },
    "header_auth": {
      "header": "Authorization",
      "value_from": "connection.oauth_access_token",
      "bearer_prefix": true
    },
    "query_mapping": {
      "per_page": "input.limit",
      "page": "input.page",
      "state": "input.state",
      "sort": "input.sort",
      "direction": "input.direction"
    },
    "omit_empty_query": true
  }
}
