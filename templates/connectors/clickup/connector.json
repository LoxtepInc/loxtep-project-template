{
  "$schema": "https://loxtep.io/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "clickup",
  "name": "ClickUp Connector",
  "description": "Connect to ClickUp via Composio to sync tasks, lists, folders, spaces, workspaces, and goals. Uses OAuth 2.0 for authorization.",
  "version": "1.0.0",
  "tags": [
    "clickup",
    "composio",
    "productivity",
    "project-management"
  ],
  "use_cases": [
    "Task and project sync",
    "Workspace hierarchy ingestion",
    "Goals and lists data integration"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "clickup",
    "name": "ClickUp",
    "description": "ClickUp project management via Composio (tasks, lists, folders, spaces, workspaces, goals)",
    "category": "productivity",
    "auth_type": "oauth2",
    "backend": "composio",
    "icon_url": "/images/connectors/clickup.svg",
    "supported_directions": [
      "inbound"
    ],
    "supported_entities": [
      "workspaces",
      "tasks",
      "spaces",
      "folders",
      "lists",
      "goals"
    ],
    "supports_webhooks": false,
    "supports_polling": true,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "clickup"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "connection_template": {
    "type": "api",
    "configuration": {}
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  },
  "connector_package": {
    "schema_version": 1,
    "package_version": "1.0.0",
    "description": "Composio toolkit wiring for ClickUp; entity → tool mapping is the source of truth for the platform ComposioAdapter.",
    "follow_up_notes": [
      "Runtime: ComposioAdapter — not CatalogRuntimeConnector; keep entity_mappings aligned with shipped Composio toolkit versions.",
      "Optional: add follow-up when ClickUp exposes stable public REST suitable for a catalog-only mirror."
    ],
    "composio_adapter": {
      "connector_type": "clickup",
      "toolkit_name": "clickup",
      "name": "ClickUp",
      "description": "ClickUp project management via Composio (tasks, lists, folders, spaces, workspaces, goals)",
      "icon_url": "/images/connectors/clickup.svg",
      "entity_mappings": [
        { "entity_type": "workspaces", "tool_slug": "CLICKUP_AUTHORIZATION_GET_WORK_SPACE_LIST" },
        { "entity_type": "tasks", "tool_slug": "CLICKUP_GET_FILTERED_TEAM_TASKS" },
        { "entity_type": "spaces", "tool_slug": "CLICKUP_GET_SPACES" },
        { "entity_type": "folders", "tool_slug": "CLICKUP_GET_FOLDERS" },
        { "entity_type": "lists", "tool_slug": "CLICKUP_GET_LISTS" },
        { "entity_type": "goals", "tool_slug": "CLICKUP_GET_GOALS" }
      ]
    },
    "actions": []
  }
}
