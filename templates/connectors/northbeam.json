{
  "$schema": "https://loxtep.com/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "northbeam",
  "name": "Northbeam Connector",
  "description": "Connect to Northbeam for multi-touch attribution. For brands with $250k+/mo ad spend.",
  "version": "1.0.0",
  "tags": ["northbeam", "attribution", "analytics", "marketing"],
  "use_cases": [
    "Multi-touch attribution",
    "Ad spend and ROAS",
    "Channel performance"
  ],
  "entity": {
