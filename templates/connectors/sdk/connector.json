  ],
  "use_cases": [
    "Write events programmatically from application code",
    "Custom ETL pipelines using the Loxtep SDK",
    "Programmatic data ingestion from any source",
    "Event-driven architecture with SDK-based producers"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "sdk",
    "name": "SDK Connector",
    "description": "Write and read events programmatically using @loxtep/sdk (Node.js) or loxtep (Python)",
    "category": "custom",
    "icon_url": null,
    "documentation_url": "https://docs.loxtep.com/connectors/sdk",
    "auth_type": "jwt",
    "oauth_config": null,
    "supported_directions": [
      "inbound",
      "outbound"
    ],
    "supported_entities": ["events"],
    "supports_webhooks": false,
    "supports_polling": false,
    "required_scopes": null,
    "required_permissions": null,
    "version": "1.1.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "sdk",
      "trigger_config_spec": {
        "required": [
          "data_product_name"
        ],
        "optional": [],
        "fields": {
          "data_product_name": {
            "type": "string",
            "description": "Name or UUID of the target data product. The SDK resolves queue, bot ID, and bus config automatically."
          }
        }
      }
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  },
  "connector_package": {
    "schema_version": 1,
    "package_version": "1.1.0",
    "description": "SDK connector for programmatic data ingestion and export. The SDK resolves all stream bus configuration (queue, bot ID, bus) from just the data product name.",
    "follow_up_notes": [
      "Install the SDK: npm install @loxtep/sdk (Node.js) or pip install loxtep (Python)",
      "Authenticate: run `loxtep login` or set LOXTEP_AUTH_TOKEN env var",
      "Export config: run `loxtep config export --from-connector <connector_id>`",
      "Write events: use client.data_products.get_writer('data_product_name')",
      "Read events: use client.data_products.get_reader('data_product_name')"
    ],
    "actions": [
      { "key": "sdk_write_events", "definition_path": "actions/write-events/definition.json" },
      { "key": "sdk_read_events", "definition_path": "actions/read-events/definition.json" }
    ]
  }
}
