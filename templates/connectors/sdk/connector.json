{
  "$schema": "https://loxtep.io/schemas/template/connector.json",
  "template_type": "connector",
  "slug": "sdk",
  "name": "SDK Connector",
  "description": "SDK-based data ingestion connector. Programmatically push events to data products via the Loxtep SDK.",
  "version": "1.0.0",
  "tags": [
    "sdk",
    "streaming",
    "ingestion",
    "programmatic"
  ],
  "use_cases": [
    "Push events from applications via SDK",
    "Stream seed data from dbt projects",
    "Custom data ingestion workflows"
  ],
  "entity": {
    "connector_id": "{{CONNECTOR_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "connector_type": "sdk",
    "name": "{{CONNECTOR_NAME}}",
    "description": "SDK-based ingestion for {{DATA_PRODUCT_NAME}}",
    "category": "sdk",
    "icon_url": null,
    "documentation_url": null,
    "auth_type": "jwt",
    "oauth_config": {
      "authorization_url": "",
      "token_url": "",
      "scopes": [],
      "response_type": "code",
      "grant_type": "authorization_code"
    },
    "supported_directions": [
      "inbound"
    ],
    "supported_entities": [
      "{{DATA_PRODUCT_NAME}}"
    ],
    "supports_webhooks": false,
    "supports_polling": false,
    "required_scopes": null,
    "required_permissions": null,
    "version": "1.0.0",
    "is_beta": false,
    "metadata": {
      "template_slug": "sdk",
      "ingestion_type": "sdk_streaming",
      "data_product_name": "{{DATA_PRODUCT_NAME}}",
      "sdk_version": "latest"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "placeholders": {
    "{{CONNECTOR_ID}}": "Generated UUID for the connector",
    "{{ORGANIZATION_ID}}": "Organization that owns this connector",
    "{{PROJECT_ID}}": "Project that contains this connector",
    "{{CONNECTOR_NAME}}": "User-provided name for the SDK connector (e.g., sdk-shopify-customers)",
    "{{DATA_PRODUCT_NAME}}": "Target data product name (e.g., shopify-customers)",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  },
  "connector_package": {
    "schema_version": 1,
    "package_version": "1.0.0",
    "description": "SDK connector for programmatic event ingestion. No HTTP actions; receives data via LoxtepClient.flows.get_writer().",
    "follow_up_notes": [
      "SDK connector does not have HTTP actions or polling logic",
      "Use with sdk-ingest workflow template for streaming data to data products",
      "Configure SDK client with organization_id, project_id, instance_id from credentials"
    ],
    "actions": []
  }
