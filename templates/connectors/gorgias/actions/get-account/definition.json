{
  "key": "gorgias_get_account",
  "name": "Get account",
  "version": "1.0.0",
  "type": "action",
  "annotations": { "read_only": true, "destructive": false },
  "input_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true
  },
  "execution": {
    "protocol": "catalog_http_get",
    "method": "GET",
    "base_url_template": "https://{{connection.custom_settings.subdomain}}.gorgias.com",
    "path": "/api/account",
    "static_headers": { "Accept": "application/json" },
    "header_auth": {
      "header": "Authorization",
      "basic": true,
      "basic_user_from": "custom_settings.email"
    }
  }
}
