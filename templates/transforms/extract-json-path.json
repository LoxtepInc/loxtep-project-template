{
  "$schema": "https://loxtep.io/schemas/transformation-package-v1.json",
  "template_type": "transform",
  "slug": "extract-json-path",
  "name": "Extract JSON Path",
  "description": "Extracts value from JSON using path expression",
  "version": "1.0.0",
  "tags": [
    "data-transformation",
    "json",
    "path"
  ],
  "use_cases": [
    "Extract nested values from complex JSON payloads",
    "Pull specific fields from deeply nested API responses",
    "Create top-level fields from JSON path expressions"
  ],
  "entity_type": "transformations",
  "entity": {
    "transformation_id": "{{TRANSFORMATION_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "workflow_id": "{{WORKFLOW_ID}}",
    "name": "{{NAME}}",
    "transform_type": "extract_json_path",
    "operation_config": {
      "field": "data",
      "path": "$.user.name",
      "output_field": "user_name"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "placeholders": {
    "{{TRANSFORMATION_ID}}": "Generated UUID for the transformation",
    "{{ORGANIZATION_ID}}": "Organization that owns this transformation",
    "{{PROJECT_ID}}": "Project that contains this transformation",
    "{{WORKFLOW_ID}}": "Workflow this transformation belongs to",
    "{{NAME}}": "User-provided name for the transformation",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
