{
  "$schema": "https://loxtep.io/schemas/transformation-package-v1.json",
  "template_type": "transform",
  "slug": "detect-sensitive-data",
  "name": "Detect Sensitive Data",
  "description": "Identifies PII/sensitive fields",
  "version": "1.0.0",
  "tags": [
    "data-quality",
    "pii",
    "privacy"
  ],
  "use_cases": [
    "Flag events containing PII before storage",
    "GDPR/CCPA compliance scanning",
    "Identify sensitive fields for encryption or masking"
  ],
  "entity_type": "transformations",
  "entity": {
    "transformation_id": "{{TRANSFORMATION_ID}}",
