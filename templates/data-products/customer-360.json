        "custom": {
          "loxtep": {
            "organization_id": "{{ORGANIZATION_ID}}",
            "domain_id": "{{DOMAIN_ID}}",
            "project_id": "{{PROJECT_ID}}",
            "workflow_id": "{{WORKFLOW_ID}}"
          }
        }
      }
    }
  },
  "placeholders": {
    "{{DATA_PRODUCT_ID}}": "Generated UUID for the data product",
    "{{ORGANIZATION_ID}}": "Organization that owns this data product",
    "{{WORKFLOW_ID}}": "Workflow (flow) that produces this data product in the graph",
    "{{PROJECT_ID}}": "Project containing the workflow",
    "{{DOMAIN_ID}}": "Domain this data product belongs to",
    "{{DATA_PRODUCT_NAME}}": "User-provided name for the data product",
    "{{USER_ID}}": "Owner user ID",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
