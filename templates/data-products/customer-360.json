      "expected_latency_ms": 5000
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}",
    "odps_document": {
      "product": {
        "details": {
          "en": {
            "name": "{{DATA_PRODUCT_NAME}}",
            "description": "Unified customer 360 profile with identity, orders, and engagement data.",
            "status": "draft",
            "tags": [
              "customer-360",
              "profile",
              "crm"
            ],
