    "owner": {
      "user_id": "{{USER_ID}}"
    },
    "status": "draft",
    "governance": {
      "classification": "internal",
      "pii_fields": [
        "email",
        "name",
        "phone"
      ],
      "compliance_requirements": [],
      "tags": [
        "customer-360",
        "profile",
        "crm"
      ]
    },
    "metadata": {
      "business_glossary": {},
