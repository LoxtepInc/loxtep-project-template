{
  "$schema": "https://loxtep.io/schemas/template/workflow.json",
  "template_type": "workflow",
  "slug": "streaming-transform",
  "name": "Streaming Transform Workflow",
  "description": "Apply real-time transformations to streaming data. Chain multiple transformations for data enrichment, filtering, aggregation, and format conversion.",
  "version": "1.0.0",
  "tags": [
    "streaming",
    "transform",
    "real-time",
    "enrichment"
  ],
  "use_cases": [
    "Real-time data enrichment",
    "Event filtering and routing",
    "Data format conversion",
    "Aggregation and windowing"
  ],
  "entity": {
    "workflow_id": "{{WORKFLOW_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "name": "{{WORKFLOW_NAME}}",
    "description": "Streaming transform workflow for real-time data processing",
    "template_id": "{{TEMPLATE_ID}}",
    "configuration": {
      "schedule": null,
      "batch_size": 200
    },
    "deployment": null,
    "status": "inactive",
    "metrics": {},
    "metadata": {
      "template_slug": "streaming-transform",
      "ingestion_type": "streaming"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}",
    "workflow_type": "ingestion",
    "domain_id": "{{DOMAIN_ID}}"
  },
  "dependencies": {
    "connection": {
      "type": "api",
      "required": false,
      "description": "Optional external API for enrichment lookups"
    },
    "transformations": {
      "required": true,
      "description": "At least one transformation must be defined"
    }
  },
  "placeholders": {
    "{{WORKFLOW_ID}}": "Generated UUID for the workflow",
    "{{ORGANIZATION_ID}}": "Organization that owns this workflow",
    "{{PROJECT_ID}}": "Project containing this workflow",
    "{{WORKFLOW_NAME}}": "User-provided name for the workflow",
    "{{TEMPLATE_ID}}": "System streaming transform template ID",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
