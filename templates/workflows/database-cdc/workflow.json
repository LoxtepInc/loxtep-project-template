{
  "$schema": "https://loxtep.io/schemas/template/workflow.json",
  "template_type": "workflow",
  "slug": "database-cdc",
  "name": "Database CDC Workflow",
  "description": "Capture database changes using Change Data Capture (CDC). Ideal for real-time data replication, event sourcing, and keeping data products in sync with operational databases.",
  "version": "1.0.0",
  "tags": [
    "database",
    "cdc",
    "real-time",
    "replication"
  ],
  "use_cases": [
    "Real-time database replication",
    "Event sourcing from transactional databases",
    "Data warehouse synchronization",
    "Audit log generation"
  ],
  "entity": {
    "workflow_id": "{{WORKFLOW_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "name": "{{WORKFLOW_NAME}}",
    "description": "Database CDC workflow for capturing database changes",
    "template_id": "{{TEMPLATE_ID}}",
    "configuration": {
      "schedule": null,
      "batch_size": 1000
    },
    "deployment": null,
    "status": "inactive",
    "metrics": {},
    "metadata": {
      "template_slug": "database-cdc",
      "ingestion_type": "database_cdc",
      "connection_ref": "Reference to database connection (add via flow canvas)",
      "cdc_config": {
        "tables": "{{CDC_TABLES}}",
        "include_schema_changes": false,
        "initial_snapshot": true
      }
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}",
    "workflow_type": "ingestion",
    "domain_id": "{{DOMAIN_ID}}"
  },
  "dependencies": {
    "connection": {
      "type": "database",
      "required": true,
      "description": "Database connection with CDC-enabled permissions"
    }
  },
  "placeholders": {
    "{{WORKFLOW_ID}}": "Generated UUID for the workflow",
    "{{ORGANIZATION_ID}}": "Organization that owns this workflow",
    "{{PROJECT_ID}}": "Project containing this workflow",
    "{{WORKFLOW_NAME}}": "User-provided name for the workflow",
    "{{TEMPLATE_ID}}": "System database CDC template ID",
    "{{CDC_TABLES}}": "Comma-separated list of tables to track (e.g., 'orders,customers')",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
