{
  "$schema": "https://loxtep.io/schemas/template/workflow.json",
  "template_type": "workflow",
  "slug": "consumption-webhook",
  "name": "Consumption Webhook Workflow",
  "description": "Deliver data product events to external consumers via outbound webhooks. Configure target URLs, payload formats, and retry policies.",
  "version": "1.0.0",
  "produces_kind": "consumer",
  "tags": [
    "consumption",
    "webhook",
    "outbound",
    "delivery"
  ],
  "use_cases": [
    "Push data to external systems",
    "Real-time event delivery",
    "Webhook-based integrations",
    "Consumer notifications"
  ],
  "entity": {
    "workflow_id": "{{WORKFLOW_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "domain_id": "{{DOMAIN_ID}}",
    "name": "{{WORKFLOW_NAME}}",
    "description": "Outbound webhook delivery workflow for data product consumption",
    "workflow_type": "consumption",
    "template_id": "{{TEMPLATE_ID}}",
    "configuration": {
      "schedule": null,
      "batch_size": 50
    },
    "deployment": null,
    "status": "inactive",
    "metrics": {},
    "metadata": {
      "template_slug": "consumption-webhook",
      "consumption_type": "webhook"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "dependencies": {
    "connection": {
      "type": "webhook",
      "required": true,
      "description": "Target webhook endpoint for event delivery"
    }
  },
  "placeholders": {
    "{{WORKFLOW_ID}}": "Generated UUID for the workflow",
    "{{ORGANIZATION_ID}}": "Organization that owns this workflow",
    "{{PROJECT_ID}}": "Project containing this workflow",
    "{{DOMAIN_ID}}": "Domain this workflow belongs to",
    "{{WORKFLOW_NAME}}": "User-provided name for the workflow",
    "{{TEMPLATE_ID}}": "Stable template ID from catalog",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
