{
  "$schema": "https://loxtep.io/schemas/export-package-v1.json",
  "template_type": "export",
  "slug": "s3-export",
  "name": "S3 Export",
  "description": "Exports workflow events to an S3 bucket in batch (e.g. Parquet, JSON, or CSV). Use for data lakes, archival, or downstream batch consumers.",
  "version": "1.0.0",
  "tags": [
    "export",
    "s3",
    "batch",
    "data-lake",
    "parquet"
  ],
  "use_cases": [
    "Data lake landing",
    "Batch archival",
    "Downstream batch processing"
  ],
  "entity": {
    "export_id": "{{EXPORT_ID}}",
    "organization_id": "{{ORGANIZATION_ID}}",
    "project_id": "{{PROJECT_ID}}",
    "name": "{{NAME}}",
    "export_type": "s3",
    "operation_config": {
      "bucket": "{{BUCKET}}",
      "prefix": "{{PREFIX}}",
      "format": "parquet",
      "batch_size": 1000,
      "schedule": "{{CRON_SCHEDULE}}"
    },
    "created_at": "{{CREATED_AT}}",
    "updated_at": "{{UPDATED_AT}}"
  },
  "placeholders": {
    "{{EXPORT_ID}}": "Generated UUID for the export",
    "{{ORGANIZATION_ID}}": "Organization that owns this export",
    "{{PROJECT_ID}}": "Project containing this export",
    "{{NAME}}": "User-provided name for the export",
    "{{BUCKET}}": "S3 bucket name",
    "{{PREFIX}}": "S3 key prefix",
    "{{CRON_SCHEDULE}}": "Cron expression for batch schedule",
    "{{CREATED_AT}}": "ISO 8601 timestamp",
    "{{UPDATED_AT}}": "ISO 8601 timestamp"
  }
}
