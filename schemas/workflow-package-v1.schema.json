{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/workflow-package-v1.json",
  "title": "Loxtep workflow package (v1)",
  "description": "Schema for a workflow template. Workflows are flow graphs that connect triggers, transformations, validations, and data products.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "workflow" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["workflow_id", "organization_id", "project_id", "name", "template_id", "workflow_type", "domain_id", "status", "created_at", "updated_at"],
      "properties": {
        "workflow_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "project_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "template_id": { "type": "string" },
        "workflow_type": { "type": "string", "enum": ["ingestion", "enrichment"] },
        "domain_id": { "type": "string" },
        "segments": { "type": "array", "default": [] },
        "trigger": { "type": ["object", "null"] },
        "configuration": {
          "type": "object",
          "properties": {
            "schedule": { "type": ["string", "null"] },
            "batch_size": { "type": ["integer", "null"], "minimum": 1 }
          },
          "additionalProperties": false
        },
        "deployment": { "type": ["object", "null"] },
        "status": { "type": "string", "enum": ["active", "paused", "error", "pending", "inactive"] },
        "metrics": { "type": "object", "additionalProperties": true },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_by": { "type": ["string", "null"] },
        "updated_by": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "deleted_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "produces_kind": {
      "type": "string",
      "enum": ["source", "consumer", "either"],
      "description": "Declares what kind of data product this workflow template produces. Used by the Source and Consumer design canvases to filter offered templates by relevance."
    },
    "dependencies": { "type": "object", "additionalProperties": true },
    "placeholders": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "additionalProperties": false
}
