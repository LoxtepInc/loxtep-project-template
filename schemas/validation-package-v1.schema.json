{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/validation-package-v1.json",
  "title": "Loxtep validation package (v1)",
  "description": "Schema for a validation node template. Defines a reusable validation rule that can be placed in a workflow flow graph to assert data quality.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "validation" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["validation_id", "organization_id", "project_id", "workflow_id", "name", "validation_type", "created_at", "updated_at"],
      "properties": {
        "validation_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "project_id": { "type": "string" },
        "workflow_id": { "type": "string" },
        "upstream_entity_id": { "type": ["string", "null"] },
        "upstream_entity_type": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "validation_type": {
          "type": "string",
          "enum": ["schema", "business_rule", "data_quality", "pii_check", "completeness", "format", "required_fields"]
        },
        "operation_config": {
          "type": "object",
          "additionalProperties": true,
          "description": "Validation-type-specific configuration (schema_ref, required_fields, condition, etc.)"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error"
        },
        "error_message": { "type": ["string", "null"] },
        "order": { "type": ["integer", "null"] },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
