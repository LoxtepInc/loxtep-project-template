{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/export-package-v1.json",
  "title": "Loxtep export package (v1)",
  "description": "Schema for an export node template. Exports deliver data product events to external destinations (S3, webhook, etc.).",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "export" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["export_id", "organization_id", "project_id", "name", "export_type", "created_at", "updated_at"],
      "properties": {
        "export_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "project_id": { "type": "string" },
        "data_product_id": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "export_type": {
          "type": "string",
          "enum": ["s3", "webhook", "database", "stream", "api_sdk", "other"]
        },
        "operation_config": {
          "type": "object",
          "additionalProperties": true,
          "description": "Export-type-specific configuration (bucket, endpoint_url, format, etc.)"
        },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
