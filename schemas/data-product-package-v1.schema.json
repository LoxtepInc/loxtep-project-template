{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/data-product-package-v1.json",
  "title": "Loxtep data product package (v1)",
  "description": "Schema for a data product node template. Defines a reusable data product that can be placed as a sink or source node in a workflow flow graph.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "data_product" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["data_product_id", "organization_id", "workflow_id", "name", "status", "created_at", "updated_at"],
      "properties": {
        "data_product_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "workflow_id": { "type": "string" },
        "domain_id": { "type": ["string", "null"] },
        "upstream_entity_id": { "type": ["string", "null"] },
        "upstream_entity_type": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "owner": {
          "type": "object",
          "required": ["user_id"],
          "properties": {
            "user_id": { "type": "string" },
            "team": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated", "archived"]
        },
        "governance": {
          "type": "object",
          "properties": {
            "classification": {
              "type": "string",
              "enum": ["public", "internal", "confidential", "restricted"]
            },
            "pii_fields": { "type": "array", "items": { "type": "string" } },
            "compliance_requirements": { "type": "array", "items": { "type": "string" } },
            "tags": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "odps_document": {
          "type": "object",
          "description": "ODPS v4.1 document. See https://loxtep.io/schemas/entity/odps-product-v1.json",
          "additionalProperties": true
        },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
