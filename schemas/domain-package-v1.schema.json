{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/domain-package-v1.json",
  "title": "Loxtep domain package (v1)",
  "description": "Schema for a domain template. Domains are logical, business-oriented groupings that organise workflows and data products.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "domain" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["domain_id", "organization_id", "name", "created_at", "updated_at"],
      "properties": {
        "domain_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "owner_user_id": { "type": ["string", "null"] },
        "parent_domain_id": { "type": ["string", "null"] },
        "is_council": { "type": "boolean", "default": false },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
