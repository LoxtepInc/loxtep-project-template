{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/trigger-package-v1.json",
  "title": "Loxtep trigger package (v1)",
  "description": "Schema for a trigger/connection node template. Triggers are the source or destination connections in a workflow flow graph.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "trigger" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity": {
      "type": "object",
      "required": ["trigger_id", "organization_id", "project_id", "key", "name", "type", "status"],
      "properties": {
        "trigger_id": { "type": "string", "description": "Unique identifier for the trigger/connection" },
        "organization_id": { "type": "string" },
        "project_id": { "type": "string" },
        "workflow_id": { "type": ["string", "null"] },
        "connector_id": { "type": ["string", "null"] },
        "upstream_entity_id": { "type": ["string", "null"] },
        "upstream_entity_type": {
          "type": ["string", "null"],
          "enum": ["connections", "transformations", "validations", "data-products", null]
        },
        "sync_entity": { "type": ["string", "null"] },
        "key": { "type": "string", "pattern": "^[a-z0-9-_]+$" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "auth_type": { "type": ["string", "null"] },
        "ingestion_type": { "type": ["string", "null"] },
        "export_type": { "type": ["string", "null"] },
        "connector_mode": { "type": ["string", "null"] },
        "credential_fields": { "type": ["object", "null"], "additionalProperties": true },
        "configuration": { "type": "object", "additionalProperties": true },
        "ingestion_config": { "type": ["object", "null"], "additionalProperties": true },
        "metadata": { "type": "object", "additionalProperties": true },
        "verified": { "type": "boolean" },
        "draft": { "type": "boolean" },
        "last_tested": { "type": ["string", "null"] },
        "created_by": { "type": ["string", "null"] },
        "updated_by": { "type": ["string", "null"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "deleted_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "placeholders": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "additionalProperties": false
}
