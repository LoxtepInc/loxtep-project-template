{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loxtep.io/schemas/transformation-package-v1.json",
  "title": "Loxtep transformation package (v1)",
  "description": "Schema for a transformation node template. Defines a reusable transform operation that can be placed in a workflow flow graph.",
  "type": "object",
  "required": ["template_type", "slug", "name", "version", "entity"],
  "properties": {
    "$schema": { "type": "string" },
    "template_type": { "type": "string", "const": "transform" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "use_cases": { "type": "array", "items": { "type": "string" } },
    "entity_type": { "type": "string", "const": "transformations" },
    "entity": {
      "type": "object",
      "required": ["transformation_id", "organization_id", "project_id", "workflow_id", "name", "transform_type", "operation_config", "created_at", "updated_at"],
      "properties": {
        "transformation_id": { "type": "string" },
        "organization_id": { "type": "string" },
        "project_id": { "type": "string" },
        "workflow_id": { "type": "string" },
        "upstream_entity_id": { "type": ["string", "null"] },
        "upstream_entity_type": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "transform_type": {
          "type": "string",
          "enum": [
            "drop_fields", "select_fields", "rename_field", "drop_null_fields",
            "drop_duplicates", "flatten", "explode_array", "array_to_column",
            "capitalize", "format_timestamp", "add_current_timestamp", "parse_json",
            "xml_to_json", "extract_json_path", "regex_extractor", "concatenate_columns",
            "derived_columns", "fill_missing_values", "detect_sensitive_data",
            "evaluate_data_quality", "change_schema", "filter", "batch", "delay", "split",
            "execute_code_function", "crypto", "formatter", "assign_identifier",
            "remove_null_events", "map", "enrich", "add_fields", "rename_fields", "custom"
          ]
        },
        "operation_config": {
          "type": "object",
          "additionalProperties": true,
          "description": "Transform-type-specific configuration parameters"
        },
        "input_schema": { "type": ["object", "null"], "additionalProperties": true },
        "output_schema": { "type": ["object", "null"], "additionalProperties": true },
        "order": { "type": ["integer", "null"] },
        "metadata": { "type": "object", "additionalProperties": true },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "placeholders": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Documentation for each {{PLACEHOLDER}} used in the entity block"
    }
  },
  "additionalProperties": false
}
